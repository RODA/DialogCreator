{
  "name": "dialog-creator",
  "version": "1.1.7",
  "description": "A dialog creating application",
  "main": "dist/main.js",
  "scripts": {
    "build": "node scripts/sync-docs-fonts.js && node scripts/sync-codicons.js && tsc && npm run bundle:cm6",
    "watch": "tsc -w",
    "lint": "eslint -c .eslintrc --ext .ts ./src",
    "start": "npm run build && node scripts/start.js",
    "docs:pdf": "node scripts/manual/build-pdf.js",
    "docs:html": "node scripts/sync-docs-fonts.js && node scripts/sync-codicons.js && node scripts/manual/build-html.js",
    "bundle:cm6": "node scripts/bundle-cm6-if-needed.js",
    "predist": "node scripts/check-env.js && node scripts/sync-docs-fonts.js && node scripts/sync-codicons.js",
    "dist": "node scripts/dist-dispatch.js",
    "dist:publish": "npm run build && electron-builder --publish onTagOrDraft",
    "rename:linux": "bash scripts/rename-binaries-linux.sh",
    "rename:mac": "bash scripts/rename-binaries-mac.sh",
    "rename:win": "powershell -ExecutionPolicy Bypass -File scripts/rename-binaries-windows.ps1"
  },
  "author": "Adrian Dusa",
  "contributors": [
    "RODA"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "bugs": {
    "url": "https://github.com/RODA/DialogCreator/issues"
  },
  "repository": "https://github.com/RODA/DialogCreator.git",
  "homepage": "https://github.com/RODA/DialogCreator#readme",
  "keywords": [
    "Electron",
    "Dialog Creator"
  ],
  "overrides": {
    "basic-ftp": "^5.2.3",
    "js-yaml": "^3.14.2",
    "preact": "^10.29.1",
    "serve-handler": "^6.1.7"
  },
  "build": {
    "appId": "DialogCreator.tool",
    "productName": "DialogCreator",
    "directories": {
      "output": "build/output",
      "buildResources": "icons"
    },
    "extraResources": [
      "LICENSE",
      {
        "from": "src/database/DialogCreator.sqlite",
        "to": "DialogCreator.sqlite"
      },
      {
        "from": "src/assets/",
        "to": "assets"
      },
      {
        "from": "docs/",
        "to": "docs"
      },
      {
        "from": "src/bundles/codemirror.bundle.js",
        "to": "bundles/codemirror.bundle.js"
      }
    ],
    "win": {
      "icon": "icons/DialogCreator.ico",
      "legalTrademarks": "Academic Non-Commercial License (see LICENSE file for details).",
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    },
    "mac": {
      "icon": "icons/DialogCreator.icns",
      "category": "public.app-category.productivity",
      "extendInfo": {
        "NSHumanReadableCopyright": "© 2025 Adrian Dusa — Academic Non-Commercial License (see LICENSE file for details)."
      },
      "target": {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    },
    "linux": {
      "target": "AppImage",
      "maintainer": "RODA",
      "icon": "icons/DialogCreator.png",
      "category": "Development / Science"
    },
    "publish": {
      "provider": "github",
      "owner": "RODA",
      "repo": "DialogCreator"
    }
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@types/emscripten": "^1.41.5",
    "@types/sqlite3": "^5.1.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.0",
    "cross-env": "^10.1.0",
    "electron": "^41.4.0",
    "electron-builder": "^26.9.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "md-to-pdf": "^5.2.5",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@jaames/iro": "^5.5.2",
    "@vscode/codicons": "^0.0.45",
    "acorn": "^8.16.0",
    "sortablejs": "^1.15.7",
    "sqlite3": "^6.0.1",
    "tippy.js": "^6.3.7",
    "uuid": "^14.0.0"
  }
}
